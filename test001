% HELPER FUNCTIONS
%% =========================================================================
function [RHS_U, RHS_V, RHS_W, RHS_Bx, RHS_By, RHS_Bz, RHS_Phi, Tr_Chk, Spin_Chk] = get_RHS(U, V, W, Bx, By, Bz, Phi, Kx, Ky, Kz, K_sq, nu, eta, g1, g2, g3, I4, g5)
    
    [Adv_U, Adv_V, Adv_W, Adv_Bx, Adv_By, Adv_Bz, Adv_Phi, Tr_Chk, Spin_Chk, Source_Phi] = compute_clifford_advection(U, V, W, Bx, By, Bz, Phi, Kx, Ky, Kz, g1, g2, g3, I4, g5);
    
    % ORSZAG 2/3 DE-ALIASING RULE
    L = 2*pi; N = size(U,1);
    k_max_sq = ( (N/2) * (2/3) * (2*pi/L) )^2; 
    dealias_mask = (K_sq <= k_max_sq);
    
    Adv_U = real(ifftn(fftn(Adv_U) .* dealias_mask)); Adv_V = real(ifftn(fftn(Adv_V) .* dealias_mask)); Adv_W = real(ifftn(fftn(Adv_W) .* dealias_mask));
    Adv_Bx = real(ifftn(fftn(Adv_Bx) .* dealias_mask)); Adv_By = real(ifftn(fftn(Adv_By) .* dealias_mask)); Adv_Bz = real(ifftn(fftn(Adv_Bz) .* dealias_mask));
    Adv_Phi = real(ifftn(fftn(Adv_Phi) .* dealias_mask)); Source_Phi = real(ifftn(fftn(Source_Phi) .* dealias_mask));
    
    % --- CRITICAL FIX: HYPER-VISCOSITY INJECTION ---
    nu_hyper = 2e-5; 
    eta_hyper = 2e-5;
    
    Diffusion_Op_Fluid  = -nu * K_sq - nu_hyper * (K_sq.^2);
    Diffusion_Op_Plasma = -eta * K_sq - eta_hyper * (K_sq.^2);
    
    % Viscous and Magnetic Diffusion in Fourier space
    U_diff = real(ifftn( Diffusion_Op_Fluid .* fftn(U) )); 
    V_diff = real(ifftn( Diffusion_Op_Fluid .* fftn(V) )); 
    W_diff = real(ifftn( Diffusion_Op_Fluid .* fftn(W) ));
    
    Bx_diff = real(ifftn( Diffusion_Op_Plasma .* fftn(Bx) )); 
    By_diff = real(ifftn( Diffusion_Op_Plasma .* fftn(By) )); 
    Bz_diff = real(ifftn( Diffusion_Op_Plasma .* fftn(Bz) ));
    
    Phi_diff = real(ifftn( Diffusion_Op_Fluid .* fftn(Phi) ));
    % -----------------------------------------------
    
    % Assemble Right-Hand Side
    RHS_U = U_diff + Adv_U; RHS_V = V_diff + Adv_V; RHS_W = W_diff + Adv_W;
    RHS_Bx = Bx_diff + Adv_Bx; RHS_By = By_diff + Adv_By; RHS_Bz = Bz_diff + Adv_Bz;
    RHS_Phi = Phi_diff - Adv_Phi + Source_Phi;
end

function [U_proj, V_proj, W_proj] = project_divergence_free(U, V, W, Kx, Ky, Kz, Inv_K_sq)
    U_hat = fftn(U); V_hat = fftn(V); W_hat = fftn(W);
    K_dot_U = Kx.*U_hat + Ky.*V_hat + Kz.*W_hat;
    U_proj_hat = U_hat - (Kx .* K_dot_U) .* Inv_K_sq;
    V_proj_hat = V_hat - (Ky .* K_dot_U) .* Inv_K_sq;
    W_proj_hat = W_hat - (Kz .* K_dot_U) .* Inv_K_sq;
    U_proj = real(ifftn(U_proj_hat)); V_proj = real(ifftn(V_proj_hat)); W_proj = real(ifftn(W_proj_hat));
end

function [Adv_U, Adv_V, Adv_W, Adv_Bx, Adv_By, Adv_Bz, Adv_Phi, Tr_Chk, Spin_Chk, Source_Phi] = compute_clifford_advection(U, V, W, Bx, By, Bz, Phi, Kx, Ky, Kz, g1, g2, g3, I4, g5)
    N = size(U, 1);
    
    U_hat = fftn(U); V_hat = fftn(V); W_hat = fftn(W); Phi_hat = fftn(Phi);
    dX_U = real(ifftn(1i .* Kx .* U_hat)); dY_U = real(ifftn(1i .* Ky .* U_hat)); dZ_U = real(ifftn(1i .* Kz .* U_hat));
    dX_V = real(ifftn(1i .* Kx .* V_hat)); dY_V = real(ifftn(1i .* Ky .* V_hat)); dZ_V = real(ifftn(1i .* Kz .* V_hat));
    dX_W = real(ifftn(1i .* Kx .* W_hat)); dY_W = real(ifftn(1i .* Ky .* W_hat)); dZ_W = real(ifftn(1i .* Kz .* W_hat));
    dX_Phi = real(ifftn(1i .* Kx .* Phi_hat)); dY_Phi = real(ifftn(1i .* Ky .* Phi_hat)); dZ_Phi = real(ifftn(1i .* Kz .* Phi_hat));
    
    Bx_hat = fftn(Bx); By_hat = fftn(By); Bz_hat = fftn(Bz);
    dX_Bx = real(ifftn(1i .* Kx .* Bx_hat)); dY_Bx = real(ifftn(1i .* Ky .* Bx_hat)); dZ_Bx = real(ifftn(1i .* Kz .* Bx_hat));
    dX_By = real(ifftn(1i .* Kx .* By_hat)); dY_By = real(ifftn(1i .* Ky .* By_hat)); dZ_By = real(ifftn(1i .* Kz .* By_hat));
    dX_Bz = real(ifftn(1i .* Kx .* Bz_hat)); dY_Bz = real(ifftn(1i .* Ky .* Bz_hat)); dZ_Bz = real(ifftn(1i .* Kz .* Bz_hat));
    
    Omega_x = dY_W - dZ_V;  Omega_y = dZ_U - dX_W;  Omega_z = dX_V - dY_U;
    Jx = dY_Bz - dZ_By;     Jy = dZ_Bx - dX_Bz;     Jz = dX_By - dY_Bx;
    
    Adv_U = (V .* Omega_z - W .* Omega_y) - (Jy .* Bz - Jz .* By);
    Adv_V = (W .* Omega_x - U .* Omega_z) - (Jz .* Bx - Jx .* Bz);
    Adv_W = (U .* Omega_y - V .* Omega_x) - (Jx .* By - Jy .* Bx);
    
    EMFx = V .* Bz - W .* By; EMFy = W .* Bx - U .* Bz; EMFz = U .* By - V .* Bx;
    EMFx_hat = fftn(EMFx); EMFy_hat = fftn(EMFy); EMFz_hat = fftn(EMFz);
    Adv_Bx = real(ifftn(1i .* Ky .* EMFz_hat - 1i .* Kz .* EMFy_hat));
    Adv_By = real(ifftn(1i .* Kz .* EMFx_hat - 1i .* Kx .* EMFz_hat));
    Adv_Bz = real(ifftn(1i .* Kx .* EMFy_hat - 1i .* Ky .* EMFx_hat));
    
    Adv_Phi = U .* dX_Phi + V .* dY_Phi + W .* dZ_Phi;
    Source_Phi = 0.005 * (Omega_x.^2 + Omega_y.^2 + Omega_z.^2); 
    
    pt = randi([1, N]);
    Z_mat = Phi(pt,pt,pt)*I4 + U(pt,pt,pt)*g1 + V(pt,pt,pt)*g2 + W(pt,pt,pt)*g3;
    DZ_mat = dX_Phi(pt,pt,pt)*g1 + dY_Phi(pt,pt,pt)*g2 + dZ_Phi(pt,pt,pt)*g3 + ...
             dX_U(pt,pt,pt)*g1*g1 + dY_U(pt,pt,pt)*g2*g1 + dZ_U(pt,pt,pt)*g3*g1 + ...
             dX_V(pt,pt,pt)*g1*g2 + dY_V(pt,pt,pt)*g2*g2 + dZ_V(pt,pt,pt)*g3*g2 + ...
             dX_W(pt,pt,pt)*g1*g3 + dY_W(pt,pt,pt)*g2*g3 + dZ_W(pt,pt,pt)*g3*g3;
             
    Commutator = 0.5 * (Z_mat * DZ_mat - DZ_mat * Z_mat);
    Tr_Chk = abs(trace(Commutator));
    Spin_Chk = abs(trace(Commutator * g5) / 4);
end

function plot_kolmogorov_spectrum(U, V, W, L, Tr_Chk, Spin_Chk)
    N = size(U, 1);
    U_hat = fftshift(fftn(U)) / N^3; V_hat = fftshift(fftn(V)) / N^3; W_hat = fftshift(fftn(W)) / N^3;
    E_3D = 0.5 * (abs(U_hat).^2 + abs(V_hat).^2 + abs(W_hat).^2);
    
    k_vec = linspace(-N/2, N/2-1, N) * (2*pi/L);
    [Kx, Ky, Kz] = meshgrid(k_vec, k_vec, k_vec);
    K_mag = sqrt(Kx.^2 + Ky.^2 + Kz.^2);
    
    K_mag_flat = round(K_mag(:) / (2*pi/L)); E_flat = E_3D(:);
    k_bins = 1:floor(N/3); E_k = zeros(size(k_bins));
    
    for i = 1:length(k_bins)
        shell_mask = (K_mag_flat == k_bins(i));
        E_k(i) = sum(E_flat(shell_mask));
    end
    
    ref_k = k_bins(2:end); ref_E = E_k(2) * (ref_k / ref_k(1)).^(-5/3);
    
    figure('Name', 'Rigorous Validation: Kolmogorov Cascade', 'Position', [150, 150, 900, 600]);
    loglog(k_bins, E_k, '-ko', 'LineWidth', 2, 'MarkerSize', 6, 'MarkerFaceColor', 'k'); hold on;
    loglog(ref_k, ref_E, '--r', 'LineWidth', 2);
    
    grid on;
    xlabel('Wave Number $k$', 'Interpreter', 'latex', 'FontSize', 14);
    ylabel('Kinetic Energy Spectrum $E(k)$', 'Interpreter', 'latex', 'FontSize', 14);
    title('3D Isotropic Kinetic Energy Spectrum ($t_{final}$)', 'Interpreter', 'latex', 'FontSize', 16);
    legend('Clifford Integrator Output', 'Kolmogorov $k^{-5/3}$ Law', 'Interpreter', 'latex', 'FontSize', 12);
    set(gca, 'FontSize', 12);
    
    log_text = sprintf(['Lie-Algebraic Conservation Logs:\n', ...
                        'Max Commutator Trace Error: %.4e\n', ...
                        'Max Chiral Ghost Error: %.4e'], Tr_Chk, Spin_Chk);
    annotation('textbox', [0.15 0.15 0.4 0.15], 'String', log_text, ...
               'FitBoxToText', 'on', 'BackgroundColor', 'w', 'EdgeColor', 'k', 'FontName', 'Courier');
end
