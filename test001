% =========================================================================
% GEOMETRIC INTEGRATOR: Topological Plasma / MHD (Tokamak Simulation)
% =========================================================================
clear; clc; close all;

%% 1. DOMAIN & FLUID PARAMETERS
N = 64;                 % Grid resolution (N^3)
L = 2*pi;               % Length of the periodic torus (T^3)
nu = 0.01;              % Kinematic viscosity (Fluid friction)
eta = 0.01;             % Magnetic diffusivity (Plasma resistance)
dt = 0.001;             % Time step

% Physical Grid 
x = linspace(0, L, N+1); x(end) = []; 
[X, Y, Z] = meshgrid(x, x, x);  

% Spectral K-Space Initialization
k_vec = (2*pi/L) * [0:(N/2-1), -N/2, (-N/2+1):-1];  
[Kx, Ky, Kz] = meshgrid(k_vec, k_vec, k_vec); 
K_sq = Kx.^2 + Ky.^2 + Kz.^2;
K_sq(1,1,1) = eps; % Protect the zero-frequency mode
Inv_K_sq = 1 ./ K_sq;

%% 2. INITIALIZING THE MULTIPHYSICS STATE
% Fluid Velocity (Taylor-Green Vortex)
U = sin(X) .* cos(Y) .* cos(Z);
V = -cos(X) .* sin(Y) .* cos(Z);
W = zeros(N, N, N);

% Magnetic Field (Orszag-Tang Magnetic Islands)
Bx = -sin(Y);
By = sin(2*X);
Bz = zeros(N, N, N);

% Active Scalar Trace Density
Phi = ones(N, N, N); 

%% 3. THE 16D DIRAC MATRIX BASIS
s0 = eye(2); s1 = [0 1; 1 0]; s2 = [0 -1i; 1i 0]; s3 = [1 0; 0 -1];
g0 = [s0, zeros(2); zeros(2), -s0];
g1 = [zeros(2), s1; -s1, zeros(2)];
g2 = [zeros(2), s2; -s2, zeros(2)];
g3 = [zeros(2), s3; -s3, zeros(2)];
g5 = 1i * g0 * g1 * g2 * g3;
I4 = eye(4);
disp('Phase 1 & 2 Complete: Multiphysics Plasma State Initialized.');

%% 4. SIMULATION PARAMETERS & VISUALIZATION SETUP
T_end = 5.0;            
num_steps = round(T_end / dt);
record_freq = 100;      

disp('Initializing 16D Topological Plasma Integrator...');
fig = figure('Name', 'MHD Tokamak Simulation: Millennium Diagnostics', 'Position', [100, 100, 1400, 800]);
time_history = []; strain_history = []; fisher_history = []; cross_helicity_history = [];

%% 5. THE TIME-STEPPING LOOP (RK3 WITH MHD)
for step = 1:num_steps
    
    % Store the current state
    U_n = U; V_n = V; W_n = W; 
    Bx_n = Bx; By_n = By; Bz_n = Bz; 
    Phi_n = Phi;
    
    % --- RK3 STAGE 1 ---
    [RHS_U, RHS_V, RHS_W, RHS_Bx, RHS_By, RHS_Bz, RHS_Phi, Tr_Chk, Spin_Chk] = get_RHS(U, V, W, Bx, By, Bz, Phi, Kx, Ky, Kz, K_sq, nu, eta, g1, g2, g3, I4, g5);
    U_1 = U + dt*RHS_U; V_1 = V + dt*RHS_V; W_1 = W + dt*RHS_W; 
    Bx_1 = Bx + dt*RHS_Bx; By_1 = By + dt*RHS_By; Bz_1 = Bz + dt*RHS_Bz; 
    Phi_1 = Phi + dt*RHS_Phi;
    [U_1, V_1, W_1] = project_divergence_free(U_1, V_1, W_1, Kx, Ky, Kz, Inv_K_sq);
    [Bx_1, By_1, Bz_1] = project_divergence_free(Bx_1, By_1, Bz_1, Kx, Ky, Kz, Inv_K_sq);
    
    % --- RK3 STAGE 2 ---
    [RHS_U, RHS_V, RHS_W, RHS_Bx, RHS_By, RHS_Bz, RHS_Phi, ~, ~] = get_RHS(U_1, V_1, W_1, Bx_1, By_1, Bz_1, Phi_1, Kx, Ky, Kz, K_sq, nu, eta, g1, g2, g3, I4, g5);
    U_2 = (3/4)*U_n + (1/4)*U_1 + (1/4)*dt*RHS_U; V_2 = (3/4)*V_n + (1/4)*V_1 + (1/4)*dt*RHS_V; W_2 = (3/4)*W_n + (1/4)*W_1 + (1/4)*dt*RHS_W;
    Bx_2 = (3/4)*Bx_n + (1/4)*Bx_1 + (1/4)*dt*RHS_Bx; By_2 = (3/4)*By_n + (1/4)*By_1 + (1/4)*dt*RHS_By; Bz_2 = (3/4)*Bz_n + (1/4)*Bz_1 + (1/4)*dt*RHS_Bz;
    Phi_2 = (3/4)*Phi_n + (1/4)*Phi_1 + (1/4)*dt*RHS_Phi;
    [U_2, V_2, W_2] = project_divergence_free(U_2, V_2, W_2, Kx, Ky, Kz, Inv_K_sq);
    [Bx_2, By_2, Bz_2] = project_divergence_free(Bx_2, By_2, Bz_2, Kx, Ky, Kz, Inv_K_sq);
    
    % --- RK3 STAGE 3 ---
    [RHS_U, RHS_V, RHS_W, RHS_Bx, RHS_By, RHS_Bz, RHS_Phi, ~, ~] = get_RHS(U_2, V_2, W_2, Bx_2, By_2, Bz_2, Phi_2, Kx, Ky, Kz, K_sq, nu, eta, g1, g2, g3, I4, g5);
    U = (1/3)*U_n + (2/3)*U_2 + (2/3)*dt*RHS_U; V = (1/3)*V_n + (2/3)*V_2 + (2/3)*dt*RHS_V; W = (1/3)*W_n + (2/3)*W_2 + (2/3)*dt*RHS_W;
    Bx = (1/3)*Bx_n + (2/3)*Bx_2 + (2/3)*dt*RHS_Bx; By = (1/3)*By_n + (2/3)*By_2 + (2/3)*dt*RHS_By; Bz = (1/3)*Bz_n + (2/3)*Bz_2 + (2/3)*dt*RHS_Bz;
    Phi = (1/3)*Phi_n + (2/3)*Phi_2 + (2/3)*dt*RHS_Phi;
    [U, V, W] = project_divergence_free(U, V, W, Kx, Ky, Kz, Inv_K_sq);
    [Bx, By, Bz] = project_divergence_free(Bx, By, Bz, Kx, Ky, Kz, Inv_K_sq);
    
    % ---------------------------------------------------------------------
    % PHASE 6: MILLENNIUM DIAGNOSTICS & LIVE 3D VISUALIZATION
    % ---------------------------------------------------------------------
    if mod(step, record_freq) == 0
        
        U_hat = fftn(U); V_hat = fftn(V); W_hat = fftn(W);
        dX_U = real(ifftn(1i .* Kx .* U_hat)); dY_V = real(ifftn(1i .* Ky .* V_hat)); dZ_W = real(ifftn(1i .* Kz .* W_hat));
        max_strain = max(sqrt(dX_U.^2 + dY_V.^2 + dZ_W.^2), [], 'all'); 
        
        if Tr_Chk > 1e-12 || Spin_Chk > 1e-12 || isnan(max_strain)
            error('FATAL ALGEBRAIC RUPTURE: Section 9 bounds violated or NaN detected.');
        end
        
        Phi_hat = fftn(Phi);
        grad_Phi_sq = real(ifftn(1i.*Kx.*Phi_hat)).^2 + real(ifftn(1i.*Ky.*Phi_hat)).^2 + real(ifftn(1i.*Kz.*Phi_hat)).^2;
        Local_Fisher = grad_Phi_sq ./ (abs(Phi) + 1e-12);
        Fisher_Info = sum(Local_Fisher, 'all') * (L/N)^3;
        Cross_Helicity = sum(U.*Bx + V.*By + W.*Bz, 'all') * (L/N)^3;
        
        time_history(end+1) = step*dt; strain_history(end+1) = max_strain; 
        fisher_history(end+1) = Fisher_Info; cross_helicity_history(end+1) = Cross_Helicity;
        
        dX_V = real(ifftn(1i .* Kx .* V_hat)); dY_U = real(ifftn(1i .* Ky .* U_hat));
        dY_W = real(ifftn(1i .* Ky .* W_hat)); dZ_V = real(ifftn(1i .* Kz .* V_hat));
        dZ_U = real(ifftn(1i .* Kz .* U_hat)); dX_W = real(ifftn(1i .* Kx .* W_hat));
        Vort_Mag = sqrt((dY_W - dZ_V).^2 + (dZ_U - dX_W).^2 + (dX_V - dY_U).^2);
        
        fprintf('Step: %04d | Time: %.3f | Max Strain: %8.4f | Fisher: %8.4f | Helicity: %8.4e\n', ...
                step, step*dt, max_strain, Fisher_Info, Cross_Helicity);
            
        clf(fig); 
        
        subplot(2,2,1);
        iso_val = prctile(Vort_Mag(:), 90); 
        p1 = patch(isosurface(X, Y, Z, Vort_Mag, iso_val));
        p1.FaceColor = 'red'; p1.EdgeColor = 'none'; camlight; lighting gouraud; alpha(0.85);
        view(3); axis tight; grid on; title(['Fluid Geometry: Vorticity Tubes (t = ', num2str(step*dt), ')']);
        
        subplot(2,2,2);
        slice(X, Y, Z, Local_Fisher, L/2, L/2, L/2);
        shading interp; colormap jet; colorbar;
        view(3); axis tight; grid on; title('Bounding Geometry');
        
        subplot(2,2,3);
        plot(time_history, cross_helicity_history, '-o', 'Color', [0.8 0.5 0], 'LineWidth', 2);
        xlabel('Time'); ylabel('$\int u \cdot B dx$', 'Interpreter', 'latex', 'FontSize', 12);
        title('Magnetic Containment (Cross-Helicity)'); grid on;
        
        subplot(2,2,4);
        plot(time_history, fisher_history, '-s', 'Color', [0 0 0.8], 'LineWidth', 2);
        xlabel('Time'); ylabel('$\int \mathcal{I}(\Phi) dx$', 'Interpreter', 'latex', 'FontSize', 12);
        title('Global Bounding Envelope'); grid on;
        
        drawnow; 
    end
end
disp('Simulation Complete: Global Regularity Maintained over discrete interval.');
plot_kolmogorov_spectrum(U, V, W, L, Tr_Chk, Spin_Chk);

