% =========================================================================
% GEOMETRIC INTEGRATOR: Geophysical Weather & Atmospheric Convection
% =========================================================================
clear; clc; close all;

%% 1. DOMAIN & GEOPHYSICAL PARAMETERS
N = 64;                 % Grid resolution
L = 2*pi;               % Periodic domain length
nu = 0.005;             % Kinematic viscosity (Air friction)
kappa = 0.005;          % Thermal diffusivity (Heat dissipation)
dt = 0.002;             % Time step

% Planetary Physics Parameters
f_coriolis = 2.0;       % Coriolis parameter (Planetary rotation speed)
g_buoyancy = 5.0;       % Gravity/Buoyancy coupling coefficient
N_Brunt = 0.5;          % Brunt-Väisälä frequency (Background atmospheric stratification)

% Physical Grid
x = linspace(0, L, N+1); x(end) = []; 
[X, Y, Z] = meshgrid(x, x, x);  

% Spectral K-Space Initialization
k_vec = (2*pi/L) * [0:(N/2-1), -N/2, (-N/2+1):-1];  
[Kx, Ky, Kz] = meshgrid(k_vec, k_vec, k_vec); 
K_sq = Kx.^2 + Ky.^2 + Kz.^2;
K_sq(1,1,1) = eps; 
Inv_K_sq = 1 ./ K_sq;

%% 2. INITIALIZING THE WEATHER STATE (Convective Storm Cell)
% The atmosphere starts completely at rest
U = zeros(N, N, N);
V = zeros(N, N, N);
W = zeros(N, N, N);

% Potential Temperature (\Phi): A massive hot air bubble near the ground (Z = pi/2)
% This will trigger a violent Rayleigh-Bénard convective updraft
Phi = 5.0 * exp( -((X-pi).^2 + (Y-pi).^2 + (Z-pi/2).^2) / 0.5 ); 

%% 3. THE 16D DIRAC MATRIX BASIS
s0 = eye(2); s1 = [0 1; 1 0]; s2 = [0 -1i; 1i 0]; s3 = [1 0; 0 -1];
g0 = [s0, zeros(2); zeros(2), -s0];
g1 = [zeros(2), s1; -s1, zeros(2)];
g2 = [zeros(2), s2; -s2, zeros(2)];
g3 = [zeros(2), s3; -s3, zeros(2)];
g5 = 1i * g0 * g1 * g2 * g3;
I4 = eye(4);

disp('Phase 1 & 2 Complete: Boussinesq Weather State Initialized.');

%% 4. SIMULATION PARAMETERS & VISUALIZATION SETUP
T_end = 3.0;            
num_steps = round(T_end / dt);
record_freq = 25;      

disp('Initializing 16D Geophysical Weather Integrator...');
fig = figure('Name', 'Atmospheric Diagnostics: Severe Convection', 'Position', [100, 100, 1400, 800]);

time_hist = []; kinetic_energy_hist = []; potential_energy_hist = []; max_w_hist = [];

%% 5. THE TIME-STEPPING LOOP (RK3 GEOPHYSICAL)
for step = 1:num_steps
    
    % Store the current state
    U_n = U; V_n = V; W_n = W; Phi_n = Phi;
    
    % --- RK3 STAGE 1 ---
    [RHS_U, RHS_V, RHS_W, RHS_Phi, Tr_Chk, Spin_Chk] = get_RHS_Weather(U, V, W, Phi, Kx, Ky, Kz, K_sq, nu, kappa, f_coriolis, g_buoyancy, N_Brunt, g1, g2, g3, I4, g5);
    U_1 = U + dt*RHS_U; V_1 = V + dt*RHS_V; W_1 = W + dt*RHS_W; Phi_1 = Phi + dt*RHS_Phi;
    [U_1, V_1, W_1] = project_divergence_free(U_1, V_1, W_1, Kx, Ky, Kz, Inv_K_sq);
    
    % --- RK3 STAGE 2 ---
    [RHS_U, RHS_V, RHS_W, RHS_Phi, ~, ~] = get_RHS_Weather(U_1, V_1, W_1, Phi_1, Kx, Ky, Kz, K_sq, nu, kappa, f_coriolis, g_buoyancy, N_Brunt, g1, g2, g3, I4, g5);
    U_2 = (3/4)*U_n + (1/4)*U_1 + (1/4)*dt*RHS_U; V_2 = (3/4)*V_n + (1/4)*V_1 + (1/4)*dt*RHS_V; W_2 = (3/4)*W_n + (1/4)*W_1 + (1/4)*dt*RHS_W;
    Phi_2 = (3/4)*Phi_n + (1/4)*Phi_1 + (1/4)*dt*RHS_Phi;
    [U_2, V_2, W_2] = project_divergence_free(U_2, V_2, W_2, Kx, Ky, Kz, Inv_K_sq);
    
    % --- RK3 STAGE 3 ---
    [RHS_U, RHS_V, RHS_W, RHS_Phi, ~, ~] = get_RHS_Weather(U_2, V_2, W_2, Phi_2, Kx, Ky, Kz, K_sq, nu, kappa, f_coriolis, g_buoyancy, N_Brunt, g1, g2, g3, I4, g5);
    U = (1/3)*U_n + (2/3)*U_2 + (2/3)*dt*RHS_U; V = (1/3)*V_n + (2/3)*V_2 + (2/3)*dt*RHS_V; W = (1/3)*W_n + (2/3)*W_2 + (2/3)*dt*RHS_W;
    Phi = (1/3)*Phi_n + (2/3)*Phi_2 + (2/3)*dt*RHS_Phi;
    [U, V, W] = project_divergence_free(U, V, W, Kx, Ky, Kz, Inv_K_sq);
    
    % ---------------------------------------------------------------------
    % PHASE 6: WEATHER DIAGNOSTICS & LIVE 3D VISUALIZATION
    % ---------------------------------------------------------------------
    if mod(step, record_freq) == 0
        
        if Tr_Chk > 1e-13 || Spin_Chk > 1e-13 
            error('FATAL ALGEBRAIC RUPTURE: Geometry broken.');
        end
        
        % Calculate Wind Kinetic Energy vs Thermal Potential Energy
        Kinetic_Energy = 0.5 * sum(U.^2 + V.^2 + W.^2, 'all') * (L/N)^3;
        Potential_Energy = 0.5 * sum(Phi.^2, 'all') * (L/N)^3;
        Max_Updraft = max(W, [], 'all'); % Max vertical wind speed
        
        time_hist(end+1) = step*dt; 
        kinetic_energy_hist(end+1) = Kinetic_Energy; 
        potential_energy_hist(end+1) = Potential_Energy;
        max_w_hist(end+1) = Max_Updraft;
        
        fprintf('Step: %04d | Time: %.3f | Kinetic E: %8.4f | Max Updraft: %8.4f\n', ...
                step, step*dt, Kinetic_Energy, Max_Updraft);
            
        clf(fig); 
        
        % PANEL 1: 3D Thermal Plume (The Storm Cell)
        subplot(2,2,1);
        iso_val = prctile(Phi(:), 95); 
        p1 = patch(isosurface(X, Y, Z, Phi, iso_val));
        p1.FaceColor = 'red'; p1.EdgeColor = 'none'; camlight; lighting gouraud; alpha(0.85);
        view(3); axis tight; grid on; zlim([0 2*pi]);
        title(['Atmospheric Thermal Plume (\theta) t = ', num2str(step*dt)]);
        
        % PANEL 2: Vertical Cross-Section of Updraft Winds (W)
        subplot(2,2,2);
        slice(X, Y, Z, W, L/2, [], []);
        shading interp; colormap jet; colorbar;
        view(3); axis tight; grid on; 
        title('Vertical Convective Wind Velocity (W)');
        
        % PANEL 3: Energy Exchange (Potential to Kinetic)
        subplot(2,2,3);
        plot(time_hist, kinetic_energy_hist, '-b', 'LineWidth', 2); hold on;
        plot(time_hist, potential_energy_hist, '-r', 'LineWidth', 2);
        xlabel('Time'); ylabel('Energy');
        legend('Wind Kinetic Energy', 'Thermal Potential Energy', 'Location', 'best');
        title('Atmospheric Energy Thermodynamics'); grid on;
        
        % PANEL 4: Peak Storm Updraft Velocity
        subplot(2,2,4);
        plot(time_hist, max_w_hist, '-o', 'Color', [0 0.5 0], 'LineWidth', 2);
        xlabel('Time'); ylabel('Max Vertical Velocity (W)');
        title('Storm Cell Updraft Intensity'); grid on;
        
        drawnow; 
    end
end
disp('Simulation Complete: Weather System Fully Developed.');

%% =========================================================================
% HELPER FUNCTIONS
%% =========================================================================

function [RHS_U, RHS_V, RHS_W, RHS_Phi, Tr_Chk, Spin_Chk] = get_RHS_Weather(U, V, W, Phi, Kx, Ky, Kz, K_sq, nu, kappa, f_coriolis, g_buoyancy, N_Brunt, g1, g2, g3, I4, g5)
    
    % 1. Extract Exact Geometric Advection
    [Adv_U, Adv_V, Adv_W, Adv_Phi, Tr_Chk, Spin_Chk] = compute_clifford_advection(U, V, W, Phi, Kx, Ky, Kz, g1, g2, g3, I4, g5);
    
    % ORSZAG 2/3 DE-ALIASING RULE
    L = 2*pi; N = size(U,1);
    k_max_sq = ( (N/2) * (2/3) * (2*pi/L) )^2; 
    dealias_mask = (K_sq <= k_max_sq);
    
    Adv_U = real(ifftn(fftn(Adv_U) .* dealias_mask)); 
    Adv_V = real(ifftn(fftn(Adv_V) .* dealias_mask)); 
    Adv_W = real(ifftn(fftn(Adv_W) .* dealias_mask));
    Adv_Phi = real(ifftn(fftn(Adv_Phi) .* dealias_mask)); 
    
    % HYPER-VISCOSITY for Deep Turbulence
    nu_hyper = 2e-5; 
    kappa_hyper = 2e-5;
    Diffusion_Op = -nu * K_sq - nu_hyper * (K_sq.^2);
    Thermal_Op   = -kappa * K_sq - kappa_hyper * (K_sq.^2);
    
    U_diff = real(ifftn( Diffusion_Op .* fftn(U) )); 
    V_diff = real(ifftn( Diffusion_Op .* fftn(V) )); 
    W_diff = real(ifftn( Diffusion_Op .* fftn(W) ));
    Phi_diff = real(ifftn( Thermal_Op .* fftn(Phi) ));
    
    % ---------------------------------------------------------------------
    % BOUSSINESQ GEOPHYSICAL FORCING (The Weather Engine)
    % ---------------------------------------------------------------------
    % 1. The Coriolis Force (f * z_hat x u) causes hurricanes to spin
    Coriolis_U = -f_coriolis * V;
    Coriolis_V =  f_coriolis * U;
    
    % 2. Thermal Buoyancy (g * Theta) forces hot air to rise
    Buoyancy_W = g_buoyancy * Phi;
    
    % 3. Background Stratification (N^2 * W) forces rising air to eventually cool and flatten out
    Stratification_Phi = - (N_Brunt^2) * W;

    % Assemble Right-Hand Side (Add standard fluid physics + Geophysical forcing)
    RHS_U = U_diff + Adv_U + Coriolis_U; 
    RHS_V = V_diff + Adv_V + Coriolis_V; 
    RHS_W = W_diff + Adv_W + Buoyancy_W;
    
    % Scalar trace advects and responds to stratification lifting
    RHS_Phi = Phi_diff - Adv_Phi + Stratification_Phi;
end

function [U_proj, V_proj, W_proj] = project_divergence_free(U, V, W, Kx, Ky, Kz, Inv_K_sq)
    % Acoustic waves are ignored in weather models (Incompressible limit)
    U_hat = fftn(U); V_hat = fftn(V); W_hat = fftn(W);
    K_dot_U = Kx.*U_hat + Ky.*V_hat + Kz.*W_hat;
    U_proj_hat = U_hat - (Kx .* K_dot_U) .* Inv_K_sq;
    V_proj_hat = V_hat - (Ky .* K_dot_U) .* Inv_K_sq;
    W_proj_hat = W_hat - (Kz .* K_dot_U) .* Inv_K_sq;
    U_proj = real(ifftn(U_proj_hat)); V_proj = real(ifftn(V_proj_hat)); W_proj = real(ifftn(W_proj_hat));
end

function [Adv_U, Adv_V, Adv_W, Adv_Phi, Tr_Chk, Spin_Chk] = compute_clifford_advection(U, V, W, Phi, Kx, Ky, Kz, g1, g2, g3, I4, g5)
    N = size(U, 1);
    
    % FFT Spatial Gradients
    U_hat = fftn(U); V_hat = fftn(V); W_hat = fftn(W); Phi_hat = fftn(Phi);
    dX_U = real(ifftn(1i .* Kx .* U_hat)); dY_U = real(ifftn(1i .* Ky .* U_hat)); dZ_U = real(ifftn(1i .* Kz .* U_hat));
    dX_V = real(ifftn(1i .* Kx .* V_hat)); dY_V = real(ifftn(1i .* Ky .* V_hat)); dZ_V = real(ifftn(1i .* Kz .* V_hat));
    dX_W = real(ifftn(1i .* Kx .* W_hat)); dY_W = real(ifftn(1i .* Ky .* W_hat)); dZ_W = real(ifftn(1i .* Kz .* W_hat));
    dX_Phi = real(ifftn(1i .* Kx .* Phi_hat)); dY_Phi = real(ifftn(1i .* Ky .* Phi_hat)); dZ_Phi = real(ifftn(1i .* Kz .* Phi_hat));
    
    % Vorticity
    Omega_x = dY_W - dZ_V;  Omega_y = dZ_U - dX_W;  Omega_z = dX_V - dY_U;
    
    % Fluid Advection (Lamb-Oseen)
    Adv_U = V .* Omega_z - W .* Omega_y;
    Adv_V = W .* Omega_x - U .* Omega_z;
    Adv_W = U .* Omega_y - V .* Omega_x;
    
    % Scalar Potential Temperature Advection
    Adv_Phi = U .* dX_Phi + V .* dY_Phi + W .* dZ_Phi;

    % 16D Clifford Commutator Conservation Verification
    pt = randi([1, N]);
    Z_mat = Phi(pt,pt,pt)*I4 + U(pt,pt,pt)*g1 + V(pt,pt,pt)*g2 + W(pt,pt,pt)*g3;
    DZ_mat = dX_Phi(pt,pt,pt)*g1 + dY_Phi(pt,pt,pt)*g2 + dZ_Phi(pt,pt,pt)*g3 + ...
             dX_U(pt,pt,pt)*g1*g1 + dY_U(pt,pt,pt)*g2*g1 + dZ_U(pt,pt,pt)*g3*g1 + ...
             dX_V(pt,pt,pt)*g1*g2 + dY_V(pt,pt,pt)*g2*g2 + dZ_V(pt,pt,pt)*g3*g2 + ...
             dX_W(pt,pt,pt)*g1*g3 + dY_W(pt,pt,pt)*g2*g3 + dZ_W(pt,pt,pt)*g3*g3;
             
    Commutator = 0.5 * (Z_mat * DZ_mat - DZ_mat * Z_mat);
    Tr_Chk = abs(trace(Commutator));
    Spin_Chk = abs(trace(Commutator * g5) / 4);
end
